{"actor":"Rohit Garud","comment":null,"created_at":"2026-03-06T07:36:32Z","event_type":"claimed","id":48,"issue_id":"agent-arsenal-kfn","new_value":"{\"assignee\":\"Rohit Garud\",\"status\":\"in_progress\"}","old_value":"{\"id\":\"agent-arsenal-kfn\",\"title\":\"FEAT: Add --dry-run flag for destructive commands\",\"description\":\"Agents need safety when running potentially destructive commands.\\n\\nExpected behavior:\\n- arsenal state clear --dry-run  # Preview what would be cleared\\n- arsenal state set key value --dry-run  # Preview what would be set\\n\\nThis allows agents to:\\n1. Preview effects before executing\\n2. Get approval from user before destructive changes\\n3. Log intended actions for debugging\",\"status\":\"open\",\"priority\":2,\"issue_type\":\"feature\",\"owner\":\"rohit.garuda1992@gmail.com\",\"created_at\":\"2026-03-05T04:45:03Z\",\"created_by\":\"Rohit Garud\",\"updated_at\":\"2026-03-05T04:45:03Z\"}"}
